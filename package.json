{
  "name": "@sethumadhavan004/ink-editor",
  "version": "0.1.0",
  "description": "A page-aware rich text editor for React document apps",
  "license": "MIT",
  "author": "Sethumadhavan",
  "workspaces": [
    "demo"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./dist/index.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "@tiptap/react": ">=2",
    "@tiptap/pm": ">=2",
    "@tiptap/starter-kit": ">=2",
    "@tiptap/extension-text-align": ">=2",
    "@tiptap/extension-underline": ">=2"
  },
  "devDependencies": {
    "@tiptap/extension-text-align": "^2.27.2",
    "@tiptap/extension-underline": "^2.27.2",
    "@tiptap/pm": "^2.11.0",
    "@tiptap/react": "^2.11.0",
    "@tiptap/starter-kit": "^2.11.0",
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "lucide-react": "^1.21.0"
  }
}
